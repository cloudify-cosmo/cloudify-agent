[Unit]
Description=Cloudify Agent Worker Service

[Service]
TimeoutStartSec=0
Restart=on-failure
{% if extra_env_path -%} EnvironmentFile=-{{ extra_env_path }} {% endif %}
User={{ user }}
RestartSec=2
ExecStart={{ virtualenv_path }}/bin/python -m cloudify_agent.worker \
    --name "{{ name }}"


[Install]
WantedBy=multi-user.target
